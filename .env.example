# Vercel Blob (for persistent sessions)
# To get this: Go to Vercel Dashboard -> Storage -> Connect Store -> Vercel Blob
BLOB_READ_WRITE_TOKEN=

# NVIDIA NIM
NIM_API_KEY=
NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NIM_REASONING_MODEL=meta/llama-3.3-70b-instruct
NIM_VISION_MODEL=meta/llama-3.2-90b-vision-instruct

# Kapruka MCP connector
KAPRUKA_MCP_BASE_URL=
KAPRUKA_MCP_API_KEY=

# Console
CONSOLE_PORT=3000

# Console — optional Ready Player Me avatar for the Talk-to-Hari concierge stage.
# Generate a free avatar at https://readyplayer.me, then append
# ?morphTargets=ARKit to the .glb URL so facial expressions + lip-sync work.
# Leave unset to use the built-in animated energy-orb avatar.
VITE_AVATAR_URL=

# Optional Lottie character pack URLs (any combination — unset states fall
# through to `packages/console/public/lottie/{state}.json`). See
# packages/console/public/lottie/README.md for full filename list.
VITE_LOTTIE_NEUTRAL_URL=
VITE_LOTTIE_TALKING_URL=
VITE_LOTTIE_LISTENING_URL=
