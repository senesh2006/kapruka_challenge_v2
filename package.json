{
  "name": "sevana",
  "version": "0.1.0",
  "private": true,
  "description": "Sevana — agentic conversational commerce platform (monorepo)",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "build:vercel": "pnpm --filter @sevana/console build",
    "lint": "eslint \"packages/*/src/**/*.{ts,tsx}\"",
    "format": "prettier --write \"packages/*/src/**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"packages/*/src/**/*.{ts,tsx,json,md}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r exec rm -rf dist node_modules .turbo"
  },
  "dependencies": {
    "@sevana/analytics": "workspace:*",
    "@sevana/connectors": "workspace:*",
    "@sevana/orchestrator": "workspace:*",
    "@sevana/shared": "workspace:*",
    "@sevana/storage": "workspace:*",
    "@vercel/blob": "^0.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@typescript-eslint/eslint-plugin": "^7.4.0",
    "@typescript-eslint/parser": "^7.4.0",
    "@vercel/node": "^3.2.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.2.5",
    "typescript": "^5.4.3",
    "vitest": "^1.4.0"
  }
}
