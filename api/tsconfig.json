{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "noEmit": true,
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "isolatedModules": false
  },
  "include": ["./**/*.ts"]
}
